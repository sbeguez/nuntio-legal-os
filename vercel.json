{
  "version": 2,
  "name": "nuntio-legal-os",
  "builds": [
    {
      "src": "nuntio-legal-os.html",
      "use": "@vercel/static"
    },
    {
      "src": "nuntio-legal-os-v2.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/v1",
      "dest": "/nuntio-legal-os.html"
    },
    {
      "src": "/",
      "dest": "/nuntio-legal-os-v2.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
